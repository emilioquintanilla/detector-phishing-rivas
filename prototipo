import streamlit as st
import joblib
import re

# Cargar el modelo entrenado (pipeline completo: preprocesamiento + clasificador)
modelo = joblib.load('modelo_phishing.pkl')

# Patrones lingüísticos de alerta, basados en la sección 6.3.2 del marco teórico
patrones_alerta = {
    r'(suspend|bloque|cancel).{0,25}(cuenta|servicio|acceso)':
        'Amenaza de suspensión o bloqueo de cuenta',
    r'(verifiqu|confirm|actualic).{0,25}(datos|contraseñ|cuenta|informaci)':
        'Solicitud de verificación de datos personales',
    r'(http|www\.|bit\.ly|tinyurl|acortado)\S*':
        'Enlace incluido en el mensaje',
    r'(gan[óo]|premio|regalo|sorteo)':
        'Oferta de premio, regalo o sorteo',
    r'(urgente|inmediato|24 horas|de inmediato|último aviso)':
        'Lenguaje de urgencia o presión de tiempo',
}

def analizar_mensaje(texto):
    """Identifica frases de alerta presentes en el texto."""
    hallazgos = []
    texto_normalizado = texto.lower()
    for patron, descripcion in patrones_alerta.items():
        if re.search(patron, texto_normalizado):
            hallazgos.append(descripcion)
    return hallazgos

# --- Interfaz de la aplicación ---
st.title("Detector de correos sospechosos — Rivas")
st.write("Pegue el texto de un correo o mensaje para analizarlo.")

texto_usuario = st.text_area("Texto del mensaje:", height=150)

if st.button("Analizar mensaje"):
    if texto_usuario.strip() == "":
        st.warning("Por favor ingrese un texto para analizar.")
    else:
        prediccion = modelo.predict([texto_usuario])[0]
        probabilidad = modelo.predict_proba([texto_usuario])[0][1]
        hallazgos = analizar_mensaje(texto_usuario)

        if prediccion == 1:
            st.error(f"Resultado: probable phishing "
                     f"(confianza: {probabilidad:.0%})")
        else:
            st.success(f"Resultado: probablemente legítimo "
                       f"(confianza: {(1 - probabilidad):.0%})")

        if hallazgos:
            st.write("Razones de la alerta:")
            for h in hallazgos:
                st.write(f"- {h}")
        else:
            st.write("No se identificaron frases de alerta conocidas.")

        st.info("Recomendación: ante cualquier duda, no haga clic en "
                "enlaces ni proporcione datos personales. Verifique "
                "directamente con la institución mencionada por un "
                "canal oficial.")
